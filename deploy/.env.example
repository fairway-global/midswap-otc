# /opt/midswap/.env — environment for the orchestrator Docker container
#
# Copy this file to /opt/midswap/.env on the GCP VM and fill in real values.
# This file is NEVER committed to the repository.
#
# To install on the VM:
#   scp deploy/.env.example deploy@YOUR_VM_IP:/opt/midswap/.env
#   ssh deploy@YOUR_VM_IP "nano /opt/midswap/.env"

# Tag to run. GitHub Actions updates this to the short SHA on each deploy,
# giving you a clear audit trail of which commit is live.
# Manually set to "latest" to always pull the most recent build.
IMAGE_TAG=latest

# ── Orchestrator secrets ─────────────────────────────────────────────────────
# Server-side Blockfrost key (preprod or mainnet — never shipped to clients).
# Get one at https://blockfrost.io — free tier is fine for preprod.
BLOCKFROST_API_KEY=preprod...

# Deployed HTLC contract address on Midnight (from setup-contract.ts output).
# This is preferred over SWAP_STATE_PATH — set one or the other, not both.
HTLC_CONTRACT_ADDRESS=5a3fc37f04c3c5bb2e957da34dfa989b9eb21513889c9dd438d000918279b457

# "preprod" or "mainnet"
MIDNIGHT_NETWORK=preprod

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins beyond the defaults.
# Add your production domain so the UI can call /api/* from the browser.
# Example: https://midswap.yourdomain.com,https://www.midswap.yourdomain.com
CORS_ORIGINS=https://YOUR_DOMAIN

# ── Logging ──────────────────────────────────────────────────────────────────
# "trace" | "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# ── Optional: stuck-swap alerting ────────────────────────────────────────────
# Post to Slack/Discord when a swap gets stuck. Leave blank to disable.
# STUCK_SWAP_WEBHOOK_URL=https://hooks.slack.com/services/...
# STUCK_SWAP_PUBLIC_UI_URL=https://YOUR_DOMAIN/reclaim
# STUCK_SWAP_SCAN_INTERVAL_MS=60000
